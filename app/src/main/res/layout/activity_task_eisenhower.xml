<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0F1E">

    <!-- Title bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#0D1326">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_revert"
            android:padding="6dp"
            android:contentDescription="Back"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Eisenhower Matrix"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- 2×2 Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="2"
        android:rowCount="2"
        android:padding="6dp">

        <!-- Q1: Do First (top-left) -->
        <LinearLayout
            android:id="@+id/quadrant1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:orientation="vertical"
            android:layout_margin="4dp"
            android:background="#0A0F1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1AEF4444"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:background="#EF4444"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔥 Do First"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvQ1Count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#EF4444"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="#1AEF4444"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerQ1"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Q2: Schedule (top-right) -->
        <LinearLayout
            android:id="@+id/quadrant2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:orientation="vertical"
            android:layout_margin="4dp"
            android:background="#0A0F1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1A3B82F6"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:background="#3B82F6"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📅 Schedule"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvQ2Count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#3B82F6"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="#1A3B82F6"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerQ2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Q3: Delegate (bottom-left) -->
        <LinearLayout
            android:id="@+id/quadrant3"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:orientation="vertical"
            android:layout_margin="4dp"
            android:background="#0A0F1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1AF59E0B"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:background="#F59E0B"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="👥 Delegate"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvQ3Count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#F59E0B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="#1AF59E0B"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerQ3"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Q4: Eliminate (bottom-right) -->
        <LinearLayout
            android:id="@+id/quadrant4"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:orientation="vertical"
            android:layout_margin="4dp"
            android:background="#0A0F1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1A64748B"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:background="#64748B"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🗑 Eliminate"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvQ4Count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="#1A64748B"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerQ4"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:padding="4dp" />
        </LinearLayout>

    </GridLayout>
</LinearLayout>
