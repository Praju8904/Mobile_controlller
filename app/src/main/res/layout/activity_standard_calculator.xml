<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0E21">

    <!-- Back button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Standard"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Display -->
    <LinearLayout
        android:id="@+id/displayArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:background="@drawable/math_display_bg"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="bottom"
        android:layout_margin="12dp">

        <TextView
            android:id="@+id/tvHistory1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#4F46E5"
            android:textSize="14sp"
            android:gravity="end"
            android:alpha="0.4"
            android:singleLine="true"
            android:ellipsize="start"/>
        <TextView
            android:id="@+id/tvHistory2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#7C3AED"
            android:textSize="14sp"
            android:gravity="end"
            android:alpha="0.5"
            android:singleLine="true"
            android:ellipsize="start"/>
        <TextView
            android:id="@+id/tvHistory3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#A5B4FC"
            android:textSize="14sp"
            android:gravity="end"
            android:alpha="0.6"
            android:singleLine="true"
            android:ellipsize="start"/>

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#C4B5FD"
            android:textSize="22sp"
            android:gravity="end"
            android:alpha="0.8"
            android:singleLine="true"
            android:ellipsize="start"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="48sp"
            android:textStyle="bold"
            android:gravity="end"
            android:singleLine="true"
            android:ellipsize="start"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- Extra row: (, ), DEL, π -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingTop="8dp">

        <Button android:id="@+id/btnOpenParen" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="(" android:textSize="18sp" android:textColor="#A5B4FC" android:background="@drawable/math_btn_function_bg"/>
        <Button android:id="@+id/btnCloseParen" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text=")" android:textSize="18sp" android:textColor="#A5B4FC" android:background="@drawable/math_btn_function_bg"/>
        <Button android:id="@+id/btnDelete" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="⌫" android:textSize="18sp" android:textColor="#EF4444" android:background="@drawable/math_btn_function_bg"/>
        <Button android:id="@+id/btnPi" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="π" android:textSize="18sp" android:textColor="#A5B4FC" android:background="@drawable/math_btn_function_bg"/>

    </LinearLayout>

    <!-- Button Grid: 4 columns x 5 rows -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:orientation="vertical"
        android:paddingHorizontal="8dp"
        android:paddingBottom="8dp">

        <!-- Row 1: C, ±, %, ÷ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <Button android:id="@+id/btnClear" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="C" android:textSize="18sp" android:textColor="#EF4444" android:background="@drawable/math_btn_function_bg"/>
            <Button android:id="@+id/btnPlusMinus" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="±" android:textSize="18sp" android:textColor="#A5B4FC" android:background="@drawable/math_btn_function_bg"/>
            <Button android:id="@+id/btnPercent" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="%" android:textSize="18sp" android:textColor="#A5B4FC" android:background="@drawable/math_btn_function_bg"/>
            <Button android:id="@+id/btnDivide" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="÷" android:textSize="22sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_operator_bg"/>
        </LinearLayout>

        <!-- Row 2: 7, 8, 9, × -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <Button android:id="@+id/btn7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="7" android:textSize="20sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_number_bg"/>
            <Button android:id="@+id/btn8" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="8" android:textSize="20sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_number_bg"/>
            <Button android:id="@+id/btn9" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="9" android:textSize="20sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_number_bg"/>
            <Button android:id="@+id/btnMultiply" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="×" android:textSize="22sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_operator_bg"/>
        </LinearLayout>

        <!-- Row 3: 4, 5, 6, − -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <Button android:id="@+id/btn4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="4" android:textSize="20sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_number_bg"/>
            <Button android:id="@+id/btn5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="5" android:textSize="20sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_number_bg"/>
            <Button android:id="@+id/btn6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="6" android:textSize="20sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_number_bg"/>
            <Button android:id="@+id/btnMinus" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="−" android:textSize="22sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_operator_bg"/>
        </LinearLayout>

        <!-- Row 4: 1, 2, 3, + -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <Button android:id="@+id/btn1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="1" android:textSize="20sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_number_bg"/>
            <Button android:id="@+id/btn2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="2" android:textSize="20sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_number_bg"/>
            <Button android:id="@+id/btn3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="3" android:textSize="20sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_number_bg"/>
            <Button android:id="@+id/btnPlus" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="+" android:textSize="22sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_operator_bg"/>
        </LinearLayout>

        <!-- Row 5: 0 (wide), ., ANS, = -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <Button android:id="@+id/btn0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2" android:layout_margin="4dp" android:text="0" android:textSize="20sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_number_bg"/>
            <Button android:id="@+id/btnDecimal" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="." android:textSize="20sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_number_bg"/>
            <Button android:id="@+id/btnAns" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="ANS" android:textSize="14sp" android:textColor="#A5B4FC" android:background="@drawable/math_btn_function_bg"/>
            <Button android:id="@+id/btnEquals" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:text="=" android:textSize="22sp" android:textColor="#FFFFFF" android:background="@drawable/math_btn_operator_bg"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
