<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0E21">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Graphing"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
        <TextView
            android:id="@+id/btnReset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset"
            android:textColor="#A5B4FC"
            android:textSize="14sp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Function inputs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingBottom="8dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="44dp" android:orientation="horizontal" android:layout_marginBottom="4dp" android:gravity="center_vertical">
            <View android:layout_width="12dp" android:layout_height="12dp" android:background="#3B82F6" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="f₁(x)=" android:textColor="#3B82F6" android:textSize="14sp"/>
            <EditText android:id="@+id/etFunc1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/math_input_bg" android:textColor="#FFFFFF" android:textSize="14sp" android:paddingHorizontal="12dp" android:inputType="text" android:hint="e.g. sin(x)" android:textColorHint="#4A4A7A"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="44dp" android:orientation="horizontal" android:layout_marginBottom="4dp" android:gravity="center_vertical">
            <View android:layout_width="12dp" android:layout_height="12dp" android:background="#8B5CF6" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="f₂(x)=" android:textColor="#8B5CF6" android:textSize="14sp"/>
            <EditText android:id="@+id/etFunc2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/math_input_bg" android:textColor="#FFFFFF" android:textSize="14sp" android:paddingHorizontal="12dp" android:inputType="text" android:hint="optional" android:textColorHint="#4A4A7A"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="44dp" android:orientation="horizontal" android:layout_marginBottom="4dp" android:gravity="center_vertical">
            <View android:layout_width="12dp" android:layout_height="12dp" android:background="#06B6D4" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="f₃(x)=" android:textColor="#06B6D4" android:textSize="14sp"/>
            <EditText android:id="@+id/etFunc3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/math_input_bg" android:textColor="#FFFFFF" android:textSize="14sp" android:paddingHorizontal="12dp" android:inputType="text" android:hint="optional" android:textColorHint="#4A4A7A"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="44dp" android:orientation="horizontal" android:gravity="center_vertical">
            <View android:layout_width="12dp" android:layout_height="12dp" android:background="#F59E0B" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="f₄(x)=" android:textColor="#F59E0B" android:textSize="14sp"/>
            <EditText android:id="@+id/etFunc4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/math_input_bg" android:textColor="#FFFFFF" android:textSize="14sp" android:paddingHorizontal="12dp" android:inputType="text" android:hint="optional" android:textColorHint="#4A4A7A"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Plot button -->
    <Button
        android:id="@+id/btnPlot"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:text="Plot Functions"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:background="@drawable/math_btn_operator_bg"/>

    <!-- Graph canvas -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="12dp"
        android:background="@drawable/math_display_bg">

        <view
            android:id="@+id/graphView"
            class="com.prajwal.myfirstapp.mathstudio.GraphingActivity$GraphView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </FrameLayout>

    <!-- X range inputs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="x:" android:textColor="#A5B4FC" android:textSize="14sp" android:layout_marginEnd="4dp"/>
        <EditText android:id="@+id/etXMin" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/math_input_bg" android:textColor="#FFFFFF" android:textSize="14sp" android:paddingHorizontal="8dp" android:inputType="numberDecimal|numberSigned" android:text="-10"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="to" android:textColor="#A5B4FC" android:textSize="14sp" android:layout_marginHorizontal="4dp"/>
        <EditText android:id="@+id/etXMax" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="@drawable/math_input_bg" android:textColor="#FFFFFF" android:textSize="14sp" android:paddingHorizontal="8dp" android:inputType="numberDecimal|numberSigned" android:text="10"/>

    </LinearLayout>

</LinearLayout>
